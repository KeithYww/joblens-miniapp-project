# This file is automatically loaded as backend/.env by local development only.
# It is ignored by Git. Production uses variables injected by Docker or the hosting platform.
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
# Development defaults. Production deployments should use TRUST_PROXY=1 and require both dependencies.
TRUST_PROXY=false
REQUIRE_DATABASE=false
REQUIRE_REDIS=false

# Required in production for persistent reports and distributed rate limiting.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/joblens
REDIS_URL=redis://localhost:6379

# siliconflow | qwen-cloud | qwencloud | rule-based
AI_PROVIDER=rule-based
SILICONFLOW_API_KEY=
# Tested with SiliconFlow JSON-mode responses. Override only with another compatible model ID.
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct
QWENCLOUD_API_KEY=
QWENCLOUD_MODEL=
QWEN_INPUT_PRICE_PER_MILLION=
QWEN_OUTPUT_PRICE_PER_MILLION=
SILICONFLOW_INPUT_PRICE_PER_MILLION=
SILICONFLOW_OUTPUT_PRICE_PER_MILLION=

# AI cost controls. Quotas reset at midnight Asia/Shanghai.
AI_CALLS_ENABLED=true
AI_DAILY_CREDIT_LIMIT=300
AI_OCR_CREDIT_COST=3
AI_ANALYSIS_CREDIT_COST=1
ANON_DAILY_OCR_LIMIT=3
ANON_DAILY_ANALYSIS_LIMIT=3
IP_DAILY_OCR_LIMIT=20
IP_DAILY_ANALYSIS_LIMIT=30
AI_MAX_TOTAL_CONCURRENCY=4
AI_MAX_OCR_CONCURRENCY=2
AI_MAX_ANALYSIS_CONCURRENCY=3
OCR_CACHE_TTL_SECONDS=86400

# Required in production when rate limits trigger a challenge.
TURNSTILE_SECRET_KEY=
CAPTCHA_BYPASS=false

# Data lifecycle controls.
DATA_CLEANUP_INTERVAL_MS=3600000

# Generate independent high-entropy values for protected operator endpoints.
MONITORING_TOKEN=
BACKUP_TOKEN=
