# Use a domain that already resolves to this server's public IP before starting Caddy.
DOMAIN=joblens.example.com
ACME_EMAIL=admin@example.com

# Generate with: openssl rand -hex 24
# Keep this value URL-safe because it is embedded in DATABASE_URL by Docker Compose.
POSTGRES_DB=joblens
POSTGRES_USER=joblens
POSTGRES_PASSWORD=replace_with_a_hex_password

# siliconflow | qwencloud | qwen-cloud
AI_PROVIDER=siliconflow
SILICONFLOW_API_KEY=
# Tested with SiliconFlow JSON-mode responses. Override only with another compatible model ID.
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct
# Used by screenshot OCR. This model accepts image data URLs.
SILICONFLOW_VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct
# Allows up to three 2MB screenshots encoded as JSON data URLs.
BODY_LIMIT_BYTES=10485760
SILICONFLOW_VISION_TIMEOUT_MS=60000
QWENCLOUD_API_KEY=
QWENCLOUD_MODEL=

# AI cost controls. Set AI_CALLS_ENABLED=false as an emergency kill switch.
AI_CALLS_ENABLED=true
AI_DAILY_CREDIT_LIMIT=300
AI_OCR_CREDIT_COST=3
AI_ANALYSIS_CREDIT_COST=1
ANON_DAILY_OCR_LIMIT=3
ANON_DAILY_ANALYSIS_LIMIT=3
IP_DAILY_OCR_LIMIT=20
IP_DAILY_ANALYSIS_LIMIT=30
AI_MAX_TOTAL_CONCURRENCY=4
AI_MAX_OCR_CONCURRENCY=2
AI_MAX_ANALYSIS_CONCURRENCY=3
OCR_CACHE_TTL_SECONDS=86400

# Cloudflare Turnstile keys for DOMAIN.
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=

# Optional; defaults to hourly when unset.
DATA_CLEANUP_INTERVAL_MS=3600000
