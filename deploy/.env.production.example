# Use a domain that already resolves to this server's public IP before starting Caddy.
DOMAIN=joblens.example.com
ACME_EMAIL=admin@example.com

# Generate with: openssl rand -hex 24
# Keep this value URL-safe because it is embedded in DATABASE_URL by Docker Compose.
POSTGRES_DB=joblens
POSTGRES_USER=joblens
POSTGRES_PASSWORD=replace_with_a_hex_password

# siliconflow | qwencloud | qwen-cloud
AI_PROVIDER=siliconflow
SILICONFLOW_API_KEY=
# Tested with SiliconFlow JSON-mode responses. Override only with another compatible model ID.
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct
QWENCLOUD_API_KEY=
QWENCLOUD_MODEL=

# Cloudflare Turnstile keys for DOMAIN.
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=

# Optional; defaults to hourly when unset.
DATA_CLEANUP_INTERVAL_MS=3600000
